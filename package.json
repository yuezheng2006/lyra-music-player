{
  "name": "lyra-music-player",
  "productName": "Lyra",
  "description": "Lyra (音波) — immersive multi-source lyric player with 3D stage",
  "author": {
    "name": "yuezheng2006",
    "email": "yuezheng2006@users.noreply.github.com"
  },
  "version": "1.0.3",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/kill-port.mjs 3000",
    "dev": "vite --port 3000 --strictPort",
    "predev:netease-api": "node scripts/kill-port.mjs 3001",
    "dev:netease-api": "node scripts/dev-netease-api.cjs",
    "predev:music-provider": "node scripts/kill-port.mjs 3002",
    "dev:music-provider": "node scripts/music-provider-sidecar.cjs",
    "predev:web": "node scripts/kill-port.mjs 3000 3001 3002",
    "dev:web": "concurrently -k \"npm run dev:netease-api\" \"npm run dev:music-provider\" \"wait-on tcp:3001 tcp:3002 && vite --port 3000 --strictPort\"",
    "predev:electron": "node scripts/kill-port.mjs 3000 3001 3002",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run -c vitest.config.ts",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:unit:watch": "vitest -c vitest.config.ts",
    "test:electron-smoke": "node test/manual/electron_smoke.mjs",
    "test:electron-click-through": "node test/manual/electron_click_through.mjs",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "benchmark:lyrics": "npx tsx test/manual/lyrics_benchmark.ts",
    "manual:lyrics": "npx tsx test/manual/netease_lyrics_cli.ts",
    "audit:lyrics-sources": "npx tsx test/manual/lyric-audit/index.ts",
    "probe:netease-xeapi": "node test/manual/netease_xeapi_probe.cjs",
    "stage:client": "vite --open /stage-client.html",
    "dev:electron": "cross-env ELECTRON_DEV=true LYRA_EXTERNAL_DEV_APIS=true LYRA_DISABLE_SINGLE_INSTANCE_LOCK=true concurrently -k \"npm run dev:netease-api\" \"npm run dev:music-provider\" \"vite --port 3000 --strictPort\" \"wait-on tcp:3000 tcp:3001 tcp:3002 && electron .\"",
    "dev:electron:dist": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true vite build && electron .",
    "dev:electron:dist:swiftshader": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=swiftshader vite build && electron .",
    "dev:electron:dist:software": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=software vite build && electron .",
    "build:electron:dir": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder --linux dir",
    "build:electron": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder",
    "contributors:add": "npx all-contributors-cli add",
    "contributors:generate": "npx all-contributors-cli generate"
  },
  "build": {
    "appId": "top.izuna.lyramusicplayer",
    "productName": "Lyra",
    "afterPack": "./scripts/electron-after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yuezheng2006",
        "repo": "lyra-music-player"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/music-provider-sidecar.cjs",
      "scripts/music-provider-adapters/**/*",
      "shared/**/*",
      "package.json",
      "build/miao.png",
      "build/thumbar/*.png"
    ],
    "asarUnpack": [
      "scripts/music-provider-sidecar.cjs",
      "scripts/music-provider-adapters/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.png",
        "to": "linux/icon.png"
      },
      {
        "from": "build/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "build/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      },
      {
        "from": "packaging/linux/lyra-music-player.desktop",
        "to": "linux/lyra-music-player.desktop"
      },
      {
        "from": "packaging/linux/README-LINUX.txt",
        "to": "linux/README-LINUX.txt"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "identity": null
    },
    "dmg": {
      "title": "${productName} ${version}",
      "window": {
        "width": 560,
        "height": 420
      },
      "contents": [
        {
          "x": 140,
          "y": 150
        },
        {
          "x": 400,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 140,
          "y": 320,
          "type": "file",
          "path": "packaging/macos/若提示已损坏请双击.command"
        },
        {
          "x": 400,
          "y": 320,
          "type": "file",
          "path": "packaging/macos/安装说明.txt"
        }
      ]
    },
    "win": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "artifactName": "${name}-${version}-linux-${arch}.${ext}",
      "target": [
        "tar.gz",
        "deb",
        "rpm"
      ],
      "publish": {
        "provider": "github",
        "publishAutoUpdate": false
      },
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "executableName": "lyra-music-player"
    }
  },
  "dependencies": {
    "@applemusic-like-lyrics/ttml": "^1.0.1",
    "@chenglou/pretext": "^0.0.7",
    "@google/genai": "^1.46.0",
    "@neteasecloudmusicapienhanced/api": "^4.35.1",
    "@xhayper/discord-rpc": "^1.3.4",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.13.1",
    "blueimp-md5": "^2.19.0",
    "buffer": "^6.0.3",
    "busboy": "^1.6.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.16.0",
    "music-metadata": "^11.12.3",
    "opencc-js": "^1.3.1",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.3.5",
    "react-window": "^2.2.7",
    "three": "^0.128.0",
    "twgl.js": "^7.0.0",
    "wanakana": "^5.3.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3",
    "wait-on": "^9.0.4"
  }
}
