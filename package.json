{
  "name": "folia-major",
  "productName": "Folia",
  "description": "Lyrics Reimagine",
  "author": {
    "name": "chthollyphile",
    "email": "chthollyphile@users.noreply.github.com"
  },
  "private": true,
  "version": "0.4.7",
  "license": "AGPL-3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run -c vitest.config.ts",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:unit:watch": "vitest -c vitest.config.ts",
    "test:ui": "playwright test",
    "test:ui:update": "playwright test --update-snapshots",
    "benchmark:lyrics": "npx tsx test/manual/lyrics_benchmark.ts",
    "stage:client": "vite --open /stage-client.html",
    "dev:electron": "cross-env ELECTRON_DEV=true concurrently -k \"vite\" \"wait-on tcp:3000 && electron .\"",
    "dev:electron:dist": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true vite build && electron .",
    "dev:electron:dist:swiftshader": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=swiftshader vite build && electron .",
    "dev:electron:dist:software": "cross-env ELECTRON_DEV=false ELECTRON=true ELECTRON_LINUX_PACKAGED_GRAPHICS=true FOLIA_LINUX_GRAPHICS_MODE=software vite build && electron .",
    "build:electron:dir": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder --linux dir",
    "build:electron": "cross-env ELECTRON_DEV=false ELECTRON=true vite build && electron-builder"
  },
  "build": {
    "appId": "top.izuna.foliamajor",
    "productName": "Folia",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "chthollyphile",
        "repo": "folia-major"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "build/miao.png",
      "build/thumbar/*.png"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "linux/icon.png"
      },
      {
        "from": "packaging/linux/folia-major.desktop",
        "to": "linux/folia-major.desktop"
      },
      {
        "from": "packaging/linux/README-LINUX.txt",
        "to": "linux/README-LINUX.txt"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "artifactName": "${name}-${version}-linux-${arch}.${ext}",
      "target": [
        "tar.gz",
        "deb",
        "rpm"
      ],
      "publish": {
        "provider": "github",
        "publishAutoUpdate": false
      },
      "icon": "build/icon.png",
      "category": "AudioVideo",
      "executableName": "folia-major"
    }
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@google/genai": "^1.46.0",
    "@neteasecloudmusicapienhanced/api": "^4.32.1",
    "axios": "^1.13.1",
    "blueimp-md5": "^2.19.0",
    "buffer": "^6.0.3",
    "busboy": "^1.6.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.16.0",
    "music-metadata": "^11.12.3",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.3.5",
    "react-window": "^2.2.7",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.10.10",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3",
    "wait-on": "^9.0.4"
  }
}
